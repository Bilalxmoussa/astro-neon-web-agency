# ============================================
# NeonCraft.me — Apache Configuration
# ============================================

# --- Force HTTPS ---
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect HTTP to HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Redirect www to non-www
  RewriteCond %{HTTP_HOST} ^www\.neoncraft\.me [NC]
  RewriteRule ^ https://neoncraft.me%{REQUEST_URI} [L,R=301]
</IfModule>

# --- 301 Redirects (migrated from vercel.json) ---
<IfModule mod_alias.c>
  RedirectMatch 301 ^/web-design-ottawa/?$ /services/web-design/
  RedirectMatch 301 ^/web-design-ottawa/restaurants/?$ /industries/restaurants/
  RedirectMatch 301 ^/web-design-ottawa/dental/?$ /industries/dental/
  RedirectMatch 301 ^/web-design-ottawa/lawyers/?$ /industries/lawyers/
  RedirectMatch 301 ^/web-design-ottawa/ecommerce/?$ /industries/ecommerce/
  RedirectMatch 301 ^/web-design-ottawa/contractors/?$ /industries/contractors/
  RedirectMatch 301 ^/web-design-ottawa/real-estate/?$ /industries/real-estate/
  RedirectMatch 301 ^/seo-ottawa/?$ /services/seo/
  RedirectMatch 301 ^/website-development-ottawa/?$ /services/responsive-development/
  RedirectMatch 301 ^/web-design-kanata/?$ /areas/kanata/
  RedirectMatch 301 ^/web-design-barrhaven/?$ /areas/barrhaven/
  RedirectMatch 301 ^/web-design-orleans/?$ /areas/orleans/
  RedirectMatch 301 ^/web-design-nepean/?$ /areas/nepean/
  RedirectMatch 301 ^/web-design-gloucester/?$ /areas/gloucester/
  RedirectMatch 301 ^/web-design-gatineau/?$ /areas/gatineau/
</IfModule>

# --- Security Headers ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-XSS-Protection "1; mode=block"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# --- Cache Control ---
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — always revalidate
  ExpiresByType text/html "access plus 0 seconds"

  # CSS & JS — 1 year (Astro hashes filenames)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Images — 30 days
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/gif "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts — 1 year
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# HTML: no-cache (revalidate every time)
<IfModule mod_headers.c>
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# --- GZIP Compression ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# --- Custom 404 ---
ErrorDocument 404 /404.html
