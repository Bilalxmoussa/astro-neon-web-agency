---
interface Props {
  heading?: string;
  subheading?: string;
  items: { question: string; answer: string }[];
}

const { heading = "Frequently Asked Questions", subheading, items } = Astro.props;
---

<section id="faq" class="py-20 bg-light">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold text-dark">{heading}</h2>
      {subheading && <p class="mt-4 text-lg text-gray">{subheading}</p>}
    </div>

    <div class="space-y-4">
      {items.map((item) => (
        <details class="group bg-white rounded-xl border border-gray-lighter overflow-hidden">
          <summary class="flex items-center justify-between cursor-pointer p-6 text-dark font-semibold hover:text-primary transition-colors list-none">
            <span class="pr-4">{item.question}</span>
            <svg class="w-5 h-5 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-6 text-gray leading-relaxed">
            <Fragment set:html={item.answer} />
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
