---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="text-sm text-gray">
  <ol class="flex items-center flex-wrap gap-1">
    {items.map((item, i) => (
      <li class="flex items-center gap-1">
        {i > 0 && (
          <svg class="w-4 h-4 text-gray-light" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {item.href ? (
          <a href={item.href} class="hover:text-primary transition-colors">{item.label}</a>
        ) : (
          <span class="text-dark font-medium">{item.label}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
