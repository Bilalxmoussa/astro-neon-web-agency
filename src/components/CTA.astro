---
import { siteConfig } from '../config/site';

interface Props {
  heading?: string;
  subheading?: string;
  buttonText?: string;
  buttonLink?: string;
}

const {
  heading = siteConfig.cta.heading,
  subheading = siteConfig.cta.subheading,
  buttonText = siteConfig.cta.buttonText,
  buttonLink = siteConfig.cta.buttonLink,
} = Astro.props;
---

<section id="contact" class="py-20 bg-gradient-to-br from-primary to-primary-dark">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-white">{heading}</h2>
    <p class="mt-4 text-lg text-white/80 max-w-2xl mx-auto">{subheading}</p>

    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={buttonLink}
        class="inline-flex items-center px-8 py-4 bg-white text-primary font-semibold rounded-lg hover:bg-light transition-colors text-lg"
      >
        {buttonText}
      </a>
      <a
        href={`tel:${siteConfig.phone.replace(/[^+\d]/g, '')}`}
        class="inline-flex items-center gap-2 px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-lg hover:bg-white/10 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {siteConfig.phone}
      </a>
    </div>

    <div class="mt-8 flex flex-wrap justify-center gap-6">
      {siteConfig.cta.features.map((feature) => (
        <div class="flex items-center gap-2 text-sm text-white/80">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          {feature}
        </div>
      ))}
    </div>
  </div>
</section>
