---
import { siteConfig } from '../config/site';

const { heading, subheading, steps } = siteConfig.process;
---

<section class="py-20 bg-light">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-dark">{heading}</h2>
      <p class="mt-4 text-lg text-gray">{subheading}</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-5 gap-8">
      {steps.map((step, i) => (
        <div class="relative">
          <div class="text-5xl font-extrabold text-primary/10">{step.number}</div>
          <h3 class="mt-2 text-lg font-semibold text-dark">{step.title}</h3>
          <p class="mt-2 text-sm text-gray leading-relaxed">{step.description}</p>
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-8 right-0 translate-x-1/2 text-primary/20">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
