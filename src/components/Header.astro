---
import { siteConfig } from '../config/site';

const currentPath = Astro.url.pathname;
const navItems = siteConfig.navigation.main;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-lighter">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 font-bold text-xl">
        <span class="gradient-text">{siteConfig.businessName}</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class={`px-3 py-2 text-sm font-medium rounded-md transition-colors ${
                currentPath.startsWith(item.href) && item.href !== '/'
                  ? 'text-primary'
                  : 'text-dark hover:text-primary'
              }`}
            >
              {item.label}
              {item.children && (
                <svg class="inline-block w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="absolute left-0 top-full pt-2 w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white rounded-lg shadow-lg border border-gray-lighter py-2">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-sm text-dark hover:bg-light hover:text-primary transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
        <a
          href={siteConfig.hero.ctaLink}
          class="ml-4 px-5 py-2 bg-primary text-white text-sm font-semibold rounded-lg hover:bg-primary-dark transition-colors"
        >
          {siteConfig.hero.ctaText}
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-dark hover:text-primary"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg id="menu-open-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4">
      <div class="flex flex-col gap-1 pt-2 border-t border-gray-lighter">
        {navItems.map((item) => (
          <>
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium text-dark hover:text-primary rounded-md"
            >
              {item.label}
            </a>
            {item.children && item.children.map((child) => (
              <a
                href={child.href}
                class="pl-6 px-3 py-1.5 text-sm text-gray hover:text-primary"
              >
                {child.label}
              </a>
            ))}
          </>
        ))}
        <a
          href={siteConfig.hero.ctaLink}
          class="mt-2 mx-3 px-5 py-2 bg-primary text-white text-sm font-semibold rounded-lg text-center hover:bg-primary-dark transition-colors"
        >
          {siteConfig.hero.ctaText}
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    openIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
