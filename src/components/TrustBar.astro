---
import { siteConfig } from '../config/site';

const { heading, logos } = siteConfig.trustBar;
---

<section class="bg-light py-10 border-y border-gray-lighter">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-medium text-gray mb-6">{heading}</p>
    <div class="flex flex-wrap justify-center items-center gap-6 md:gap-10">
      {logos.map((logo) => (
        <div class="flex items-center justify-center w-12 h-12 bg-white rounded-lg shadow-sm border border-gray-lighter">
          <span class="text-sm font-bold text-primary">{logo.initial}</span>
        </div>
      ))}
    </div>
  </div>
</section>
