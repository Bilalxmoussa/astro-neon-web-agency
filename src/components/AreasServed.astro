---
import { siteConfig } from '../config/site';

const areas = siteConfig.areas;
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-dark">Serving Businesses Across the Ottawa Region</h2>
      <p class="mt-4 text-lg text-gray">We provide web design services throughout Ottawa and the National Capital Region.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {areas.map((area) => (
        <a href={`/areas/${area.slug}/`} class="group p-6 bg-light rounded-xl border border-gray-lighter card-hover block">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center">
              <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-dark group-hover:text-primary transition-colors">Web Design {area.name}</h3>
          </div>
          <p class="text-sm text-gray leading-relaxed">{area.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>
