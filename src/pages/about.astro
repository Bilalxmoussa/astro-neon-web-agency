---
import PageLayout from '../layouts/PageLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTA from '../components/CTA.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import { siteConfig } from '../config/site';
---

<PageLayout title="About Neon Web Agency - Ottawa Web Design" description="Learn about Neon Web Agency, Ottawa's trusted web design agency. Founded in 2018, we've launched 150+ websites for businesses across the National Capital Region.">
  <Fragment slot="head">
    <BreadcrumbSchema items={[{ label: 'Home', href: '/' }, { label: 'About' }]} />
  </Fragment>

  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'About' }]} />

      <h1 class="mt-8 text-4xl sm:text-5xl font-bold text-dark">About Neon Web Agency</h1>
      <p class="mt-4 text-xl text-gray leading-relaxed">
        Ottawa's trusted web design agency, helping small businesses build powerful online presences since {siteConfig.foundingYear}.
      </p>

      <div class="mt-12 space-y-8 text-gray leading-relaxed">
        <div>
          <h2 class="text-2xl font-bold text-dark mb-4">Our Story</h2>
          <p>
            Neon Web Agency was founded in {siteConfig.foundingYear} by {siteConfig.author.name} with a simple mission: help Ottawa small businesses compete online with professional, high-performance websites that actually drive results. What started as a one-person operation has grown into a full-service web design agency serving businesses across the National Capital Region.
          </p>
          <p class="mt-4">
            Over the years, we've launched more than 150 websites for businesses in Ottawa, Kanata, Barrhaven, Orleans, Nepean, Gloucester, and Gatineau. Our clients span every industry — from dental clinics and law firms to restaurants, contractors, and tech companies. We take pride in our 98% client satisfaction rate and our 4.9-star Google rating.
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-dark mb-4">Our Approach</h2>
          <p>
            We believe every business deserves a website that works as hard as they do. That means no templates, no cookie-cutter solutions, and no compromises on quality. Every website we build is custom-designed, mobile-responsive, SEO-optimized, and engineered to convert visitors into customers.
          </p>
          <p class="mt-4">
            We combine stunning design with data-driven strategy. Every design decision is backed by research into your market, your competitors, and your target audience. The result is a website that not only looks exceptional but delivers measurable business results.
          </p>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-dark mb-4">Meet the Founder</h2>
          <div class="bg-light p-6 rounded-xl border border-gray-lighter">
            <h3 class="text-xl font-semibold text-dark">{siteConfig.author.name}</h3>
            <p class="text-sm text-primary font-medium">{siteConfig.author.title}</p>
            <p class="mt-3 text-gray">{siteConfig.author.bio}</p>
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-dark mb-4">Why Choose Us</h2>
          <div class="grid sm:grid-cols-2 gap-6">
            <div class="p-4 bg-light rounded-lg">
              <h3 class="font-semibold text-dark">Local Expertise</h3>
              <p class="mt-1 text-sm">Deep understanding of the Ottawa market, its demographics, and competitive landscape.</p>
            </div>
            <div class="p-4 bg-light rounded-lg">
              <h3 class="font-semibold text-dark">Results-Driven</h3>
              <p class="mt-1 text-sm">Every website is designed to generate leads, sales, and measurable business growth.</p>
            </div>
            <div class="p-4 bg-light rounded-lg">
              <h3 class="font-semibold text-dark">Transparent Pricing</h3>
              <p class="mt-1 text-sm">No hidden fees or surprises. You know exactly what you're investing in from day one.</p>
            </div>
            <div class="p-4 bg-light rounded-lg">
              <h3 class="font-semibold text-dark">Long-Term Partnership</h3>
              <p class="mt-1 text-sm">We don't disappear after launch. Ongoing support and optimization to keep you growing.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</PageLayout>
