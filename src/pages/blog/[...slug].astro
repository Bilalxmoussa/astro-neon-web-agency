---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import CTA from '../../components/CTA.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import ArticleSchema from '../../components/schema/ArticleSchema.astro';
import BreadcrumbSchema from '../../components/schema/BreadcrumbSchema.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const slug = post.id.replace(/\.md$/, '');
    return {
      params: { slug },
      props: { post, slug },
    };
  });
}

const { post, slug } = Astro.props;
const { Content } = await post.render();

const relatedBlogLinks = (post.data.relatedBlogSlugs || []).map((slug: string) => ({
  label: slug.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase()),
  href: `/blog/${slug}/`,
}));

const relatedIndustryLinks = (post.data.relatedIndustrySlugs || []).map((slug: string) => ({
  label: slug.replace(/-/g, ' ').replace(/\b\w/g, (l: string) => l.toUpperCase()) + ' Web Design',
  href: `/industries/${slug}/`,
}));
---

<BlogLayout
  title={post.data.metaTitle}
  description={post.data.metaDescription}
  datePublished={post.data.datePublished}
  readTime={post.data.readTime}
>
  <Fragment slot="head">
    <ArticleSchema
      title={post.data.title}
      description={post.data.metaDescription}
      datePublished={post.data.datePublished}
      dateModified={post.data.dateModified}
      url={`/blog/${slug}/`}
    />
    <BreadcrumbSchema items={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog/' },
      { label: post.data.title },
    ]} />
  </Fragment>

  <Content />

  {relatedBlogLinks.length > 0 && (
    <div class="mt-16">
      <InternalLinks heading="Related Articles" links={relatedBlogLinks} />
    </div>
  )}

  {relatedIndustryLinks.length > 0 && (
    <div class="mt-8">
      <InternalLinks heading="Related Industries" links={relatedIndustryLinks} />
    </div>
  )}
</BlogLayout>

<CTA />
