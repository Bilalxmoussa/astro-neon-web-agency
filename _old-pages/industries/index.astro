---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTA from '../../components/CTA.astro';
import BreadcrumbSchema from '../../components/schema/BreadcrumbSchema.astro';
import WebPageSchema from '../../components/schema/WebPageSchema.astro';
import { getCollection } from 'astro:content';
import { siteConfig } from '../../config/site';

const industries = await getCollection('industries');
---

<PageLayout title="Industry Web Design Ottawa - Neon Web Agency" description="Specialized web design for Ottawa industries. Restaurants, dental, legal, e-commerce, contractors, and real estate websites tailored to your market.">
  <Fragment slot="head">
    <WebPageSchema title="Industry Web Design Ottawa" description="Specialized web design for Ottawa industries" url="/industries/" />
    <BreadcrumbSchema items={[{ label: 'Home', href: '/' }, { label: 'Industries' }]} />
  </Fragment>

  <Hero
    headline="Industry Web Design"
    suffix="Tailored to Your Market"
    subheadline="We build specialized websites for Ottawa's key industries, each optimized for your specific audience and business goals."
    ctaText="Get a Free Quote"
    ctaLink={siteConfig.cta.buttonLink}
  />

  <section class="py-8 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Industries' }]} />
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {industries.map((ind) => (
          <a href={`/industries/${ind.id}/`} class="group p-8 bg-light rounded-xl border border-gray-lighter card-hover block">
            <h2 class="text-xl font-bold text-dark group-hover:text-primary transition-colors">{ind.data.title}</h2>
            <p class="mt-3 text-gray text-sm leading-relaxed">{ind.data.heroDescription}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {ind.data.stats.slice(0, 2).map((stat) => (
                <span class="text-xs font-medium px-2 py-1 bg-primary/10 text-primary rounded-full">
                  {stat.value} {stat.label}
                </span>
              ))}
            </div>
            <span class="inline-flex items-center mt-4 text-sm font-medium text-primary">
              Learn more
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-dark mb-6">Explore Our Services & Areas</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <div>
          <h3 class="font-semibold text-dark mb-3">Our Services</h3>
          <ul class="space-y-2">
            {siteConfig.services.map((s) => (
              <li><a href={`/services/${s.slug}/`} class="text-sm text-primary hover:underline">{s.title}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-dark mb-3">Areas We Serve</h3>
          <ul class="space-y-2">
            {siteConfig.navigation.main.find(n => n.label === 'Areas')?.children?.map((area) => (
              <li><a href={area.href} class="text-sm text-primary hover:underline">Web Design {area.label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-dark mb-3">Resources</h3>
          <ul class="space-y-2">
            <li><a href="/blog/web-design-cost-ottawa/" class="text-sm text-primary hover:underline">How Much Does Web Design Cost?</a></li>
            <li><a href="/blog/how-to-choose-web-designer-ottawa/" class="text-sm text-primary hover:underline">How to Choose a Web Designer</a></li>
            <li><a href="/blog/local-seo-guide-ottawa/" class="text-sm text-primary hover:underline">Local SEO Guide for Ottawa</a></li>
            <li><a href="/blog/small-business-seo-tips/" class="text-sm text-primary hover:underline">Small Business SEO Tips</a></li>
            <li><a href="/blog/" class="text-sm text-primary hover:underline">View All Blog Posts →</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</PageLayout>
